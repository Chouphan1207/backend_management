generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String      @id @default(uuid())
  name      String
  email     String   @unique
  password  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
    categories Category[]
    tasks      Task[]
}

model Category {
  id        String   @id @default(uuid())
  title     String
  icon      String?
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Ownership: Tracks which category belongs to which user
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relation to tasks
  tasks     Task[]

  // Ensures a user cannot create duplicate categories with the exact same title
  @@unique([userId, title])
  @@index([userId])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model Task {
  id          String     @id @default(uuid())
  title       String
  // 2. Replace boolean with the new Status enum, defaulting to TODO
  status      TaskStatus @default(TODO)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  String?
  category    Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([categoryId])
}
